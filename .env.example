# Database
DATABASE_URL=postgresql://user:pass@postgres:5432/db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce_db

# Authentication
JWT_SECRET=your-secret-key
JWT_EXPIRATION=15m

# AI / API keys
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key
MISTRAL_API_KEY=your-mistral-key

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=ur-email@gmail.com
SMTP_TO=your-email@gmail.com

# Internal service URLs
SCRAPER_URL=http://scraper:5001
SOCIAL_URL=http://social:5002
DETECTOR_URL=http://detector:5003
SEARCH_KEYWORD_CONCURRENCY=3
SEARCH_MAX_BRIGHT_DATA_ATTEMPTS=3

# ─────────────────────────────────────────────
# DETECTOR SERVICE - AI MODELS
# ─────────────────────────────────────────────
DETECTOR_GEMINI_MODEL=gemini-2.5-flash
DETECTOR_GROQ_MODEL=llama-3.1-8b-instant
DETECTOR_MISTRAL_MODEL=mistral-small-latest

#BRIGHT DATA
BRIGHT_DATA_API_URL=https://api.brightdata.com/request
BRIGHT_DATA_API_KEY=your_api_key
BRIGHT_DATA_ZONE=your_web_unlocker_zone
BRIGHT_DATA_FORMAT=raw
BRIGHT_DATA_MIN_CREDITS=100