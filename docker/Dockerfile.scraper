FROM python:3.11-slim

# This Dockerfile is intended for use by docker-compose orchestration.
# Use `docker/Dockerfile.scraper` when building all services together.

WORKDIR /app

# Install base system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
  wget gnupg ca-certificates build-essential \
  && rm -rf /var/lib/apt/lists/*

# Install pip requirements
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browser binaries and all required OS dependencies
RUN python -m playwright install --with-deps chromium || true

# Copy application code from build context (services/scraper)
COPY app/ ./

EXPOSE 5001
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "5001"]
